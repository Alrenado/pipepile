---
---

<div class="lightbox" id="lightbox" aria-hidden="true">
    <button class="lightbox__close" aria-label="Close">×</button>

    <div class="embla-main">
        <div class="embla-main__container"></div>
        <button class="embla-main__btn embla-main__btn--prev" aria-label="Previous">‹</button>
        <button class="embla-main__btn embla-main__btn--next" aria-label="Next">›</button>
    </div>

    <div class="embla-thumbs">
        <div class="embla-thumbs__container"></div>
    </div>
</div>

<style lang="scss" is:global>
  @use '../styles/abstracts/variables' as *;
  @use '../styles/abstracts/mixins' as *;

  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 100;
    background: $color-bg-placeholder;
    @include flex-center;
    flex-direction: column;

    gap: $spacing-lg;
    padding: $spacing-xl;

    opacity: 0;
    pointer-events: none;
    transition: opacity $transition-slow;

    &.is-open {
      opacity: 1;
      pointer-events: all;
    }
  }

  .lightbox__close {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    background: none;
    border: none;
    color: $color-bg-light;
    font-size: 2.5rem;
    cursor: pointer;
    line-height: 1;
  }

  .embla-main {
    position: relative;
    width: 100%;
    max-width: 900px;
    overflow: hidden;
  }

  .embla-main__container {
    display: flex;
  }

  .embla-main__slide {
    flex: 0 0 100%;
    min-width: 0;

    img {
      width: 100%;
      max-height: 65vh;
      object-fit: contain;
      border-radius: $radius-lg;
    }
  }

  .embla-main__btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255,255,255,0.15);
    border: none;
    color: $color-bg-light;
    font-size: 2rem;
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;

    &--prev { left: 0.5rem; }
    &--next { right: 0.5rem; }
  }

  .embla-thumbs {
    width: 100%;
    max-width: 900px;
    overflow: hidden;
  }

  .embla-thumbs__container {
    display: flex;
    gap: 0.5rem;
  }

  .embla-thumbs__slide {
    flex: 0 0 80px;
    min-width: 0;
    cursor: pointer;
    opacity: 0.4;
    transition: opacity 0.2s ease;

    &.is-active {
      opacity: 1;
    }

    img {
      width: 100%;
      height: 60px;
      object-fit: cover;
      border-radius: 0.5rem;
    }
  }
</style>

<script>
  import EmblaCarousel from 'embla-carousel'

  document.addEventListener('astro:page-load', () => {
    const lightbox = document.getElementById('lightbox')!
    const mainNode = lightbox.querySelector('.embla-main') as HTMLElement
    const mainContainer = lightbox.querySelector('.embla-main__container') as HTMLElement
    const thumbsNode = lightbox.querySelector('.embla-thumbs') as HTMLElement
    const thumbsContainer = lightbox.querySelector('.embla-thumbs__container') as HTMLElement

    let emblaMain: ReturnType<typeof EmblaCarousel> | null = null
    let emblaThumbs: ReturnType<typeof EmblaCarousel> | null = null

    window.addEventListener('lightbox:open', (e: Event) => {
      const { images, startIndex } = (e as CustomEvent<{ images: string[], startIndex: number }>).detail

      mainContainer.innerHTML = ''
      thumbsContainer.innerHTML = ''

      images.forEach(src => {
        const slide = document.createElement('div')
        slide.className = 'embla-main__slide'
        const img = document.createElement('img')
        img.src = src
        slide.appendChild(img)
        mainContainer.appendChild(slide)

        const thumb = document.createElement('div')
        thumb.className = 'embla-thumbs__slide'
        const thumbImg = document.createElement('img')
        thumbImg.src = src
        thumb.appendChild(thumbImg)
        thumbsContainer.appendChild(thumb)
      })

      emblaMain = EmblaCarousel(mainNode, { loop: true, startIndex })
      emblaThumbs = EmblaCarousel(thumbsNode, { containScroll: 'keepSnaps', dragFree: true })

      const updateThumbs = () => {
        const selected = emblaMain!.selectedScrollSnap()
        thumbsContainer.querySelectorAll('.embla-thumbs__slide').forEach((el, i) => {
          el.classList.toggle('is-active', i === selected)
        })
        emblaThumbs!.scrollTo(selected)
      }

      thumbsContainer.querySelectorAll('.embla-thumbs__slide').forEach((el, i) => {
        el.addEventListener('click', () => emblaMain!.scrollTo(i))
      })

      emblaMain.on('select', updateThumbs)
      updateThumbs()

      lightbox.querySelector('.embla-main__btn--prev')
        ?.addEventListener('click', () => emblaMain!.scrollPrev())
      lightbox.querySelector('.embla-main__btn--next')
        ?.addEventListener('click', () => emblaMain!.scrollNext())

      lightbox.classList.add('is-open')
      lightbox.setAttribute('aria-hidden', 'false')
      document.documentElement.classList.add('menu-locked')
    })

    const close = () => {
      lightbox.classList.remove('is-open')
      lightbox.setAttribute('aria-hidden', 'true')
      document.documentElement.classList.remove('menu-locked')
      emblaMain?.destroy()
      emblaThumbs?.destroy()
    }

    lightbox.querySelector('.lightbox__close')?.addEventListener('click', close)
    lightbox.addEventListener('click', e => { if (e.target === lightbox) close() })
    document.addEventListener('keydown', e => { if (e.key === 'Escape') close() })
  })
</script>
