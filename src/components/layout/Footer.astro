---
import Logo from './Logo.astro'
const base = import.meta.env.BASE_URL
const basePath = base.endsWith('/') ? base : `${base}/`
---

<footer class="footer">
    <div class="footer__container">
        <div class="footer__wrapper footer__navigaion">
            <div class="footer__accordion">
                <button class="footer__accordion-toggle" aria-expanded="false">
                    <span class="footer__accordion-title" data-i18n="footer.accordionTitle"></span>
                    <span class="footer__accordion-icon"></span>
                </button>
                <nav class="footer__nav">
                    <ul class="footer__list">
                        <li><a href={`${basePath}gallery`}       data-i18n="header.gallery"       class="footer__link"></a></li>
                        <li><a href={`${basePath}manufacturing`}  data-i18n="header.manufacturing"  class="footer__link"></a></li>
                        <li><a href={`${basePath}documentation`}  data-i18n="header.documentation"  class="footer__link"></a></li>
                        <li><a href={`${basePath}contacts`}       data-i18n="header.contacts"       class="footer__link"></a></li>
                    </ul>
                </nav>
            </div>
            <Logo width={206} height={60}/>
        </div>
        <div class="footer__wrapper footer__privacy">
            <span data-i18n="footer.privacy"></span>
            <div class="lang-switch">
                <button class="lang-switch__btn" data-lang="ua">UA</button>
                <span>|</span>
                <button class="lang-switch__btn" data-lang="en">EN</button>
            </div>
        </div>
    </div>
</footer>

<style lang="scss">
  @use '../../styles/abstracts/variables' as *;
  @use '../../styles/abstracts/mixins' as *;

  .footer {
    padding: $spacing-xl 0;

    &__container {
      display: flex;
      flex-direction: column;
      gap: $spacing-3xl;
    }

    &__wrapper {
      width: 100%;
      max-width: $container-max;
      margin: 0 auto;
      padding: 0 $container-padding;
      @include flex-between;
    }

    &__list {
      display: flex;
      gap: $spacing-lg;
    }

    &__link {
      color: $color-text;
      transition: color $transition-base;

      &:hover {
        color: $color-text-selected;
      }
    }

    &__copy {
      font-size: 0.875rem;
      color: $color-text-selected;
    }

    &__accordion-toggle {
      display: none;
    }

    @include respond-to(lg) {
      &__navigaion {
        flex-direction: column;
        align-items: flex-start;
        gap: $spacing-md;
      }
      &__accordion {
        width: 100%;
      }

      &__accordion-toggle {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
        background: none;
        border: none;
        padding: $spacing-sm 0;
        font-size: 1rem;
        font-weight: $font-weight-medium;
        cursor: pointer;
      }

      &__accordion-icon {
        display: inline-block;
        width: 10px;
        height: 10px;
        border-right: 2px solid $color-text;
        border-bottom: 2px solid $color-text;
        transform: rotate(45deg);
        transition: transform $transition-base;
      }

      &__accordion-toggle[aria-expanded="true"] &__accordion-icon {
        transform: rotate(-135deg);
      }

      &__nav {
        overflow: hidden;
        max-height: 0;
        transition: max-height $transition-slow;
      }

      &__accordion-toggle[aria-expanded="true"] + &__nav {
        max-height: 300px;
      }

      &__list {
        flex-direction: column;
        gap: $spacing-sm;
        padding: $spacing-md 0;
      }
      &__privacy {
        flex-direction: column;
        justify-content: center;
        gap: $spacing-md;
      }
    }
  }
</style>

<script>
    import {applyTranslations, getCurrentLang} from '../../scripts/translations'

    document.addEventListener('astro:page-load', () => {
        applyTranslations(getCurrentLang())

        const toggle = document.querySelector('.footer__accordion-toggle')
        if (toggle) {
            toggle.addEventListener('click', () => {
                const expanded = toggle.getAttribute('aria-expanded') === 'true'
                toggle.setAttribute('aria-expanded', String(!expanded))
            })
        }
    })
</script>
