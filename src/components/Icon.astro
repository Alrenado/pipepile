---
interface Props {
    name: string
    size?: number
    class?: string
    label?: string
}

const { name, size = 24, class: className, label } = Astro.props
---

<svg
        width={size}
        height={size}
        class={className}
        aria-label={label}
        aria-hidden={!label ? 'true' : undefined}
        role={label ? 'img' : undefined}
>
    <use href={`/sprite.svg#icon-${name}`} />
</svg>

<style>
    svg {
        display: inline-block;
        vertical-align: middle;
        flex-shrink: 0;
        fill: none;
    }
</style>