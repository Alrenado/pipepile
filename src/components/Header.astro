---
import Logo from './Logo.astro'
const base = import.meta.env.BASE_URL
const basePath = base.endsWith('/') ? base : `${base}/`

const links = [
    { href: `${basePath}gallery`,      'data-i18n': 'header.gallery' },
    { href: `${basePath}manufacturing`, 'data-i18n': 'header.manufacturing' },
    { href: `${basePath}documentation`, 'data-i18n': 'header.documentation' },
    { href: `${basePath}contacts`,      'data-i18n': 'header.contacts' },
]
---

<header class="header">
    <div class="header__container">
        <Logo width={107} height={50} />

        <nav class="header__nav">
            <ul class="header__list">
                {links.map(link => (
                        <li>
                            <a href={link.href} data-i18n={link['data-i18n']} class="header__link"></a>
                        </li>
                ))}
            </ul>
        </nav>

        <div class="lang-switch">
            <button class="lang-switch__btn" data-lang="ua">UA</button>
            <span>|</span>
            <button class="lang-switch__btn" data-lang="en">EN</button>
        </div>

        <button class="header__burger" aria-label="Menu">
            <span></span>
            <span></span>
            <span></span>
        </button>
    </div>
</header>

<style lang="scss">
    @use '../styles/abstracts/variables' as *;
    @use '../styles/abstracts/mixins' as *;

    .header {
      position: fixed;
      width: 100%;
      padding: $spacing-2xl 0;
      z-index: 10;

      &::before {
        content: '';
        position: fixed;
        inset: 0;
        background: rgba(255, 255, 255, 0.6);
        backdrop-filter: blur(12px);
        opacity: 0;
        pointer-events: none;
        transition: 0.3s;
      }

      &__container {
        max-width: $container-max;
        margin: 0 auto;
        padding: 0 $container-padding;
        @include flex-between;
        font-weight: $font-weight-medium;
        font-size: font-clamp(1rem);
      }

      &__list {
        display: flex;
        gap: $spacing-2xl;
      }

      &__burger {
        display: none;
        flex-direction: column;
        gap: 5px;

        span {
          width: 25px;
          height: 2px;
          background: $color-text;
          transition: 0.3s;
        }
      }

      &__nav {
        display: flex;
      }

      @include respond-to(md) {

        &__burger {
          display: flex;
        }

        &__nav {
          position: fixed;
          inset: 0;
          background: $color-bg-light;

          display: flex;
          flex-direction: column;

          justify-content: center;
          align-items: center;

          opacity: 0;
          pointer-events: none;
          transform: translateY(-10px);
          transition: 0.3s;
        }

        &__list {
          flex-direction: column;
          gap: 2rem;
          align-items: center;
        }

        .lang-switch {
          display: none;
        }

        &--open {

          &::before {
            opacity: 1;
            pointer-events: all;
          }

          .header__nav {
            opacity: 1;
            pointer-events: all;
            transform: translateY(0);
          }

          .header__list {
            flex-direction: column;
            gap: 2rem;
          }

          .lang-switch {
            display: flex;

            position: fixed;

            bottom: 60px;
            left: 50%;
            transform: translateX(-50%);

            flex-direction: row;
            gap: 10px;

            z-index: 21;
          }

          .header__burger span:nth-child(1) {
            transform: rotate(45deg) translateY(6px);
          }

          .header__burger span:nth-child(2) {
            opacity: 0;
          }

          .header__burger span:nth-child(3) {
            transform: rotate(-45deg) translateY(-6px);
          }
        }
      }
    }
</style>

<script>
    import { setLang, getCurrentLang, applyTranslations } from '../scripts/translations'
    import type { Lang } from '../scripts/i18n'

    document.addEventListener('astro:page-load', () => {
        const lang = getCurrentLang()
        const header = document.querySelector('.header')
        const burger = document.querySelector('.header__burger')

        document.querySelectorAll('.lang-switch__btn').forEach(btn => {
            btn.classList.toggle('lang-switch__btn--active', btn.dataset.lang === lang)
        })

        document.querySelectorAll('.lang-switch__btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const selected = btn.dataset.lang as Lang
                setLang(selected)
                document.querySelectorAll('.lang-switch__btn').forEach(b => {
                    b.classList.toggle('lang-switch__btn--active', b.dataset.lang === selected)
                })
            })
        })

        applyTranslations(lang)

        burger?.addEventListener('click', () => {
            header?.classList.toggle('header--open')
        })
    })
</script>