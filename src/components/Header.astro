---
import Logo from './Logo.astro'
const base = import.meta.env.BASE_URL
const basePath = base.endsWith('/') ? base : `${base}/`

const links = [
    { href: `${basePath}gallery`,      'data-i18n': 'header.gallery' },
    { href: `${basePath}manufacturing`, 'data-i18n': 'header.manufacturing' },
    { href: `${basePath}documentation`, 'data-i18n': 'header.documentation' },
    { href: `${basePath}contacts`,      'data-i18n': 'header.contacts' },
]
---

<header class="header">
    <div class="header__container">
        <Logo width={200} height={58} />

        <nav class="header__nav">
            <ul class="header__list">
                {links.map(link => (
                        <li>
                            <a href={link.href} data-i18n={link['data-i18n']} class="header__link"></a>
                        </li>
                ))}
            </ul>
        </nav>

        <div class="lang-switch">
            <button class="lang-switch__btn" data-lang="ua">UA</button>
            <span>|</span>
            <button class="lang-switch__btn" data-lang="en">EN</button>
        </div>

        <button class="header__burger" aria-label="Menu" aria-expanded="false">
            <span></span>
            <span></span>
            <span></span>
        </button>
    </div>
</header>

<style is:global>
    html.menu-locked,
    html.menu-locked body {
        overflow: hidden;
    }
    html.menu-locked body {
        position: fixed;
        width: 100%;
    }
</style>

<style lang="scss">
    @use '../styles/abstracts/variables' as *;
    @use '../styles/abstracts/mixins' as *;

    .header {
      position: fixed;
      width: 100%;
      padding: $spacing-2xl 0;
      z-index: 10;
      transition: background 0.3s;

      &--scrolled {
        background-image: linear-gradient(to right, $color-white, $color-bg-blue);
      }

      &::before {
        content: '';
        position: fixed;
        inset: 0;
        background: rgba(255, 255, 255, 0.6);
        backdrop-filter: blur(12px);
        opacity: 0;
        pointer-events: none;
        transition: 0.3s;
      }

      &__container {
        max-width: $container-max;
        margin: 0 auto;
        padding: 0 $container-padding;
        @include flex-between;
        font-weight: $font-weight-medium;
        font-size: font-clamp(1rem);
      }

      &__list {
        display: flex;
        gap: $spacing-2xl;
      }

      &__link {
        color: $color-text;
        transition: color $transition-base;

        &:hover {
          color: $color-text-selected;
        }
      }

      .lang-switch {
        &__btn {
          color: $color-text;
          transition: color $transition-base;

          &:hover {
            color: $color-text-selected;
          }
        }
      }

      &__burger {
        display: none;
        position: relative;
        z-index: 20;
        width: 25px;
        height: 16px;
        padding: 0;
        margin: 0;
        border: none;
        background: none;
        cursor: pointer;
        -webkit-appearance: none;
        appearance: none;
        flex-shrink: 0;

        span {
          display: block;
          position: absolute;
          left: 0;
          width: 25px;
          height: 2px;
          background: $color-text;
          border-radius: 1px;
          transition: transform 0.3s ease, opacity 0.3s ease;
          transform-origin: center center;

          &:nth-child(1) { top: 0;    } // center y = 1px
          &:nth-child(2) { top: 7px;  } // center y = 8px
          &:nth-child(3) { top: 14px; } // center y = 15px
        }
      }

      &__nav {
        display: flex;
      }

      @include respond-to(lg) {

        &__burger {
          display: block;
        }

        &__nav {
          position: fixed;
          inset: 0;
          background: $color-bg-light;

          display: flex;
          flex-direction: column;

          justify-content: center;
          align-items: center;

          opacity: 0;
          pointer-events: none;
          transform: translateY(-10px);
          transition: 0.3s;
        }

        &__list {
          flex-direction: column;
          gap: 2rem;
          align-items: center;
        }

        .lang-switch {
          display: none;
        }

        &--open {

          &::before {
            opacity: 1;
            pointer-events: all;
          }

          .header__nav {
            opacity: 1;
            pointer-events: all;
            transform: translateY(0);
          }

          .header__list {
            flex-direction: column;
            gap: 2rem;
          }

          .lang-switch {
            display: flex;
            position: fixed;
            bottom: 60px;
            left: 50%;
            transform: translateX(-50%);
            flex-direction: row;
            gap: 10px;
            z-index: 21;
          }
          .header__burger span:nth-child(1) {
            transform: translateY(7px) rotate(45deg);
          }

          .header__burger span:nth-child(2) {
            opacity: 0;
          }
          .header__burger span:nth-child(3) {
            transform: translateY(-7px) rotate(-45deg);
          }
        }
      }
    }
</style>

<script>
    import { setLang, getCurrentLang, applyTranslations } from '../scripts/translations'
    import type { Lang } from '../scripts/i18n'

    let abortCtrl = new AbortController()

    document.addEventListener('astro:before-swap', () => {
        abortCtrl.abort()
        abortCtrl = new AbortController()
    })

    document.addEventListener('astro:page-load', () => {
        const signal = abortCtrl.signal
        const lang = getCurrentLang()
        const header = document.querySelector('.header') as HTMLElement | null
        const burger = document.querySelector('.header__burger') as HTMLElement | null
        const nav = document.querySelector('.header__nav')

        document.querySelectorAll('.lang-switch__btn').forEach(btn => {
            btn.classList.toggle('lang-switch__btn--active', (btn as HTMLElement).dataset.lang === lang)
        })

        document.querySelectorAll('.lang-switch__btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const selected = (btn as HTMLElement).dataset.lang as Lang
                setLang(selected)
                document.querySelectorAll('.lang-switch__btn').forEach(b => {
                    b.classList.toggle('lang-switch__btn--active', (b as HTMLElement).dataset.lang === selected)
                })
            }, { signal })
        })

        applyTranslations(lang)

        let savedScrollY = 0

        function lockScroll() {
            savedScrollY = window.scrollY
            document.body.style.top = `-${savedScrollY}px`
            document.documentElement.classList.add('menu-locked')
        }

        function unlockScroll() {
            document.documentElement.classList.remove('menu-locked')
            document.body.style.top = ''
            window.scrollTo(0, savedScrollY)
        }

        function openMenu() {
            header?.classList.add('header--open')
            burger?.setAttribute('aria-expanded', 'true')
            lockScroll()
        }

        function closeMenu() {
            if (!header?.classList.contains('header--open')) return
            header.classList.remove('header--open')
            burger?.setAttribute('aria-expanded', 'false')
            unlockScroll()
        }

        function toggleMenu() {
            header?.classList.contains('header--open') ? closeMenu() : openMenu()
        }

        burger?.addEventListener('click', toggleMenu, { signal })

        const onScroll = () => {
            header?.classList.toggle('header--scrolled', window.scrollY > 50)
        }
        onScroll()
        window.addEventListener('scroll', onScroll, { signal, passive: true })

        nav?.querySelectorAll('.header__link').forEach(link => {
            link.addEventListener('click', closeMenu, { signal })
        })

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') closeMenu()
        }, { signal })

        let touchStartX = 0
        let touchStartY = 0

        document.addEventListener('touchstart', (e) => {
            if (!header?.classList.contains('header--open')) return
            touchStartX = e.touches[0].clientX
            touchStartY = e.touches[0].clientY
        }, { signal, passive: true })

        document.addEventListener('touchend', (e) => {
            if (!header?.classList.contains('header--open')) return
            const dx = e.changedTouches[0].clientX - touchStartX
            const dy = e.changedTouches[0].clientY - touchStartY
            const adx = Math.abs(dx)
            const ady = Math.abs(dy)

            if ((dx < -60 && adx > ady) || (dy < -60 && ady > adx)) {
                closeMenu()
            }
        }, { signal, passive: true })
    })
</script>
