---
import Section from '../components/Section.astro'
import Carousel from '../components/Carousel.astro'

import AppImage from '../components/AppImage.astro'
import firstPicture from '../assets/index-1.jpeg'
import secondPicture from '../assets/index-2.jpeg'
import thirdPicture from '../assets/index-3.jpeg'
import fourthPicture from '../assets/index-4.jpeg'
import fifthPicture from '../assets/index-5.jpeg'
import sixthPicture from '../assets/index-6.jpeg'
import seventhPicture from '../assets/index-7.jpeg'
import eighthPicture from '../assets/index-8.jpeg'

const carouselCard = [
    {image: firstPicture, imageAlt: 'index-1'},
    {image: secondPicture, imageAlt: 'index-2'},
    {image: thirdPicture, imageAlt: 'index-3'},
    {image: fourthPicture, imageAlt: 'index-4'},
    {image: fifthPicture, imageAlt: 'index-5'},
    {image: sixthPicture, imageAlt: 'index-6'},
    {image: seventhPicture, imageAlt: 'index-7'},
    {image: eighthPicture, imageAlt: 'index-8'}
]

---

<Section class="production">
    <Carousel>
        {carouselCard.map(({ image, imageAlt }) => (
            <div class="embla__slide">
                <AppImage src={image} alt={imageAlt} />
            </div>
        ))}
    </Carousel>
</Section>