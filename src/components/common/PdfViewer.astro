---
interface Props {
    src: string
    title?: string
}

const { src, title = 'Document' } = Astro.props
const base = import.meta.env.BASE_URL
const basePath = base.endsWith('/') ? base : `${base}/`
const pdfUrl = src.startsWith('http') ? src : `${basePath}${src.replace(/^\//, '')}`
---

<div class="pdf-viewer" data-pdf-url={pdfUrl}>
    <div class="pdf-viewer__toolbar">
        <div class="pdf-viewer__toolbar-left">
            <button class="pdf-viewer__btn" id="pdf-prev" aria-label="Предыдущая страница" disabled>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
            </button>
            <div class="pdf-viewer__page-nav">
                <input class="pdf-viewer__page-input" id="pdf-page-num" type="number" value="1" min="1" />
                <span class="pdf-viewer__page-sep">/</span>
                <span class="pdf-viewer__page-total" id="pdf-page-total">—</span>
            </div>
            <button class="pdf-viewer__btn" id="pdf-next" aria-label="Следующая страница" disabled>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
        </div>

        <div class="pdf-viewer__toolbar-center">
            <span class="pdf-viewer__title">{title}</span>
        </div>

        <div class="pdf-viewer__toolbar-right">
            <button class="pdf-viewer__btn" id="pdf-zoom-out" aria-label="Уменьшить">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
            </button>
            <span class="pdf-viewer__zoom-level" id="pdf-zoom-level">100%</span>
            <button class="pdf-viewer__btn" id="pdf-zoom-in" aria-label="Увеличить">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
            </button>
            <div class="pdf-viewer__divider"></div>
            <a class="pdf-viewer__btn pdf-viewer__btn--download" href={pdfUrl} download aria-label="Скачать PDF">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            </a>
            <button class="pdf-viewer__btn" id="pdf-fullscreen" aria-label="На весь экран">
                <svg class="icon-expand" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 3H5a2 2 0 0 0-2 2v3"/><path d="M21 8V5a2 2 0 0 0-2-2h-3"/><path d="M3 16v3a2 2 0 0 0 2 2h3"/><path d="M16 21h3a2 2 0 0 0 2-2v-3"/></svg>
                <svg class="icon-compress" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none"><path d="M8 3v3a2 2 0 0 1-2 2H3"/><path d="M21 8h-3a2 2 0 0 1-2-2V3"/><path d="M3 16h3a2 2 0 0 1 2 2v3"/><path d="M16 21v-3a2 2 0 0 1 2-2h3"/></svg>
            </button>
        </div>
    </div>

    <div class="pdf-viewer__body" id="pdf-body">
        <div class="pdf-viewer__pages" id="pdf-pages"></div>
        <div class="pdf-viewer__loading" id="pdf-loading">
            <span>Загрузка...</span>
        </div>
        <div class="pdf-viewer__error" id="pdf-error" hidden>
            <span>Не удалось загрузить PDF</span>
        </div>
    </div>
</div>

<script>
    const PDFJS_VERSION = '3.11.174'

    async function initPdfViewer(container: HTMLElement) {
        const url = container.dataset.pdfUrl!
        const body = container.querySelector('#pdf-body') as HTMLElement
        const pages = container.querySelector('#pdf-pages') as HTMLElement
        const loading = container.querySelector('#pdf-loading') as HTMLElement
        const error = container.querySelector('#pdf-error') as HTMLElement
        const prevBtn = container.querySelector('#pdf-prev') as HTMLButtonElement
        const nextBtn = container.querySelector('#pdf-next') as HTMLButtonElement
        const pageInput = container.querySelector('#pdf-page-num') as HTMLInputElement
        const pageTotal = container.querySelector('#pdf-page-total') as HTMLElement
        const zoomLevelEl = container.querySelector('#pdf-zoom-level') as HTMLElement
        const zoomInBtn = container.querySelector('#pdf-zoom-in') as HTMLButtonElement
        const zoomOutBtn = container.querySelector('#pdf-zoom-out') as HTMLButtonElement
        const fullscreenBtn = container.querySelector('#pdf-fullscreen') as HTMLButtonElement
        const iconExpand = fullscreenBtn?.querySelector('.icon-expand') as SVGElement
        const iconCompress = fullscreenBtn?.querySelector('.icon-compress') as SVGElement

        const pdfjsLib = (window as any).pdfjsLib
        if (!pdfjsLib) return

        pdfjsLib.GlobalWorkerOptions.workerSrc =
            `https://cdnjs.cloudflare.com/ajax/libs/pdf.js/${PDFJS_VERSION}/pdf.worker.min.js`

        let pdfDoc: any = null
        let scale = 1.2
        let currentPage = 1
        const canvases: HTMLCanvasElement[] = []

        async function renderAllPages() {
            pages.innerHTML = ''
            canvases.length = 0

            for (let i = 1; i <= pdfDoc.numPages; i++) {
                const page = await pdfDoc.getPage(i)
                const viewport = page.getViewport({ scale })

                const wrapper = document.createElement('div')
                wrapper.className = 'pdf-viewer__page'
                wrapper.dataset.page = String(i)

                const canvas = document.createElement('canvas')
                canvas.width = viewport.width
                canvas.height = viewport.height

                const ctx = canvas.getContext('2d')!
                await page.render({ canvasContext: ctx, viewport }).promise

                wrapper.appendChild(canvas)
                pages.appendChild(wrapper)
                canvases.push(canvas)
            }

            setupIntersectionObserver()
        }

        function setupIntersectionObserver() {
            const observer = new IntersectionObserver((entries) => {
                let maxRatio = 0
                let visiblePage = currentPage
                entries.forEach(entry => {
                    if (entry.intersectionRatio > maxRatio) {
                        maxRatio = entry.intersectionRatio
                        const page = parseInt((entry.target as HTMLElement).dataset.page!)
                        if (page) visiblePage = page
                    }
                })
                if (maxRatio > 0) {
                    currentPage = visiblePage
                    pageInput.value = String(currentPage)
                    prevBtn.disabled = currentPage <= 1
                    nextBtn.disabled = currentPage >= pdfDoc.numPages
                }
            }, { root: body, threshold: [0, 0.25, 0.5, 0.75, 1] })

            pages.querySelectorAll('.pdf-viewer__page').forEach(el => observer.observe(el))
        }

        function scrollToPage(num: number) {
            const target = pages.querySelector(`[data-page="${num}"]`) as HTMLElement
            if (target) {
                body.scrollTo({ top: target.offsetTop - 16, behavior: 'smooth' })
            }
        }

        function updateZoom(delta: number) {
            scale = Math.min(3, Math.max(0.5, scale + delta))
            zoomLevelEl.textContent = Math.round(scale / 1.2 * 100) + '%'
            renderAllPages()
        }

        try {
            pdfDoc = await pdfjsLib.getDocument(url).promise
            const total = pdfDoc.numPages
            pageTotal.textContent = String(total)
            pageInput.max = String(total)
            prevBtn.disabled = false
            nextBtn.disabled = false
            loading.hidden = true
            await renderAllPages()
        } catch {
            loading.hidden = true
            error.hidden = false
            return
        }

        prevBtn.addEventListener('click', () => {
            if (currentPage > 1) scrollToPage(--currentPage)
        })
        nextBtn.addEventListener('click', () => {
            if (currentPage < pdfDoc.numPages) scrollToPage(++currentPage)
        })
        pageInput.addEventListener('change', () => {
            const n = parseInt(pageInput.value)
            if (n >= 1 && n <= pdfDoc.numPages) {
                currentPage = n
                scrollToPage(currentPage)
            }
        })
        zoomInBtn.addEventListener('click', () => updateZoom(0.2))
        zoomOutBtn.addEventListener('click', () => updateZoom(-0.2))

        fullscreenBtn?.addEventListener('click', () => {
            if (!document.fullscreenElement) {
                container.requestFullscreen()
            } else {
                document.exitFullscreen()
            }
        })

        document.addEventListener('fullscreenchange', () => {
            const isFullscreen = !!document.fullscreenElement
            iconExpand.style.display = isFullscreen ? 'none' : ''
            iconCompress.style.display = isFullscreen ? '' : 'none'
            fullscreenBtn.setAttribute('aria-label', isFullscreen ? 'Выйти из полного экрана' : 'На весь экран')
        })
    }

    document.addEventListener('astro:page-load', () => {
        const container = document.querySelector('.pdf-viewer') as HTMLElement
        if (!container) return

        if ((window as any).pdfjsLib) {
            initPdfViewer(container)
            return
        }

        const script = document.createElement('script')
        script.src = `https://cdnjs.cloudflare.com/ajax/libs/pdf.js/${PDFJS_VERSION}/pdf.min.js`
        script.onload = () => initPdfViewer(container)
        document.head.appendChild(script)
    })
</script>
