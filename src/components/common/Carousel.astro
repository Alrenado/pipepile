---
---

<div class="embla">
    <div class="embla__container">
        <slot />
    </div>

    <button class="embla__btn embla__btn--prev" aria-label="Previous">‹</button>
    <button class="embla__btn embla__btn--next" aria-label="Next">›</button>

    <div class="embla__dots"></div>
</div>

<style lang="scss">
  @use '../../styles/abstracts/variables' as *;

  .embla {
    position: relative;
    overflow: hidden;
    padding-bottom: $radius-lg;
    margin-bottom: -$radius-lg;
  }

  .embla__container {
    display: flex;
  }

  .embla__btn {
    position: absolute;
    top: 40%;
    transform: translateY(-50%);
    z-index: 1;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    border: none;
    background: $color-bg-light;
    cursor: pointer;
    font-size: 1.25rem;
    display: flex;
    align-items: center;
    justify-content: center;

    &--prev { left: 1rem; }
    &--next { right: 1rem; }
  }

  .embla__dots {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 1.5rem;
  }

  :global(.embla__dot) {
    width: 0.625rem;
    height: 0.625rem;
    border-radius: 50%;
    border: none;
    background: $color-placeholder;
    cursor: pointer;
    padding: 0;
    transition: background 0.3s ease;

    &:global(.embla__dot--active) {
      background: $color-text-selected;
    }
  }
</style>

<script>
    import EmblaCarousel from 'embla-carousel'

    document.addEventListener('astro:page-load', () => {
        document.querySelectorAll('.embla').forEach(emblaNode => {
            const container = emblaNode.querySelector('.embla__container') as HTMLElement
            const dotsNode = emblaNode.querySelector('.embla__dots') as HTMLElement
            if (!container) return

            const embla = EmblaCarousel(emblaNode as HTMLElement, {
                loop: true,
                align: 'start',
            })

            emblaNode.querySelector('.embla__btn--prev')
                ?.addEventListener('click', () => embla.scrollPrev())
            emblaNode.querySelector('.embla__btn--next')
                ?.addEventListener('click', () => embla.scrollNext())

            const dots: HTMLButtonElement[] = embla.scrollSnapList().map((_, i) => {
                const dot = document.createElement('button')
                dot.classList.add('embla__dot')
                dot.addEventListener('click', () => embla.scrollTo(i))
                dotsNode.appendChild(dot)
                return dot
            })

            const updateDots = () => {
                const selected = embla.selectedScrollSnap()
                dots.forEach((dot, i) => {
                    dot.classList.toggle('embla__dot--active', i === selected)
                })
            }

            embla.on('select', updateDots)
            updateDots()

            const slides = emblaNode.querySelectorAll('.embla__slide')

            slides.forEach((slide, i) => {
                slide.addEventListener('click', () => {
                    // Собираем src в момент клика — браузер уже выбрал формат
                    const images = Array.from(slides).map(s => {
                        const img = s.querySelector('img')
                        return img?.currentSrc || img?.src || ''
                    }).filter(Boolean)

                    window.dispatchEvent(new CustomEvent('lightbox:open', {
                        detail: { images, startIndex: i }
                    }))
                })
            })
        })
    })
</script>
