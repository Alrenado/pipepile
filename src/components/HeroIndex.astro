---
import Section from '../components/Section.astro'

import AppImage from '../components/AppImage.astro'
import pipeDiagram from '../assets/pipe-diagram.jpg'
import pipeHighlight from '../assets/pipe-highlight.jpg'
---

<Section class="hero" paddingTop="8rem">
    <div class="hero__text">
        <p data-i18n-html="hero.title"></p>
        <p data-i18n-html="hero.subtitle"></p>
    </div>

    <div class="hero__images">
        <AppImage
                src={pipeDiagram}
                alt="pipe-diagram"
                width={686}
                height={501}
                priority={true}
                sizes="686px"
                quality={90}
        />
        <AppImage
                src={pipeHighlight}
                alt="pipe-highlight"
                width={686}
                height={501}
                priority={true}
                sizes="686px"
                quality={90}
        />
    </div>
</Section>

<style lang="scss">
  @use '../styles/abstracts/variables' as *;
  @use '../styles/abstracts/mixins' as *;

  .hero {
    &__text {
      flex: 7;
      min-width: 0;
      overflow-wrap: break-word;
      display: flex;
      flex-direction: column;
    }

    &__images {
      flex: 5;
      display: flex;
      flex-direction: column;
      gap: 2.5rem;
    }
  }

  @include respond-to(lg) {
    .hero {
      &__text,
      &__images {
        flex: none;
        width: 100%;
      }

      &__images {
        order: -1;
      }
    }
  }
</style>