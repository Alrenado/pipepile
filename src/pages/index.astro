---
import BaseLayout from '../layouts/BaseLayout.astro'
import HeroIndex from '../components/HeroIndex.astro'
import Slogan from '../components/Slogan.astro'
import Features from '../components/Features.astro'
import Production from '../components/Production.astro'
---

<BaseLayout title="Pipepile">
	<HeroIndex/>
	<Slogan/>
	<Features/>
	<Production/>

</BaseLayout>

<script>
	import { applyTranslations, getCurrentLang } from '../scripts/translations'

	document.addEventListener('astro:page-load', () => {
		applyTranslations(getCurrentLang())
	})
</script>