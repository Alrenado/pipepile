---
import BaseLayout from '../layouts/BaseLayout.astro'
import HeroIndex from '../components/index/HeroIndex.astro'
import Slogan from '../components/index/Slogan.astro'
import Features from '../components/index/Features.astro'
import Production from '../components/index/Production.astro'
---

<BaseLayout
	title="Pipepile — Виробництво сталевих труб в Україні"
	description="Виробництво та постачання сталевих труб в Україні. Широкий асортимент, власне виробництво, доставка по всій країні."
>
	<HeroIndex/>
	<Slogan/>
	<Features/>
	<Production/>

</BaseLayout>

<script>
	import { applyTranslations, getCurrentLang } from '../scripts/translations'

	document.addEventListener('astro:page-load', () => {
		applyTranslations(getCurrentLang())
	})
</script>